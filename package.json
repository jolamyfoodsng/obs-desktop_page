{
  "name": "obs-desktop",
  "private": true,
  "version": "0.30.0",
  "type": "module",
  "scripts": {
    "check:release-version": "node scripts/check-release-version.mjs",
    "dev": "tauri dev",
    "dev:ui": "vite",
    "build": "node scripts/sync-updater-pubkey.mjs && tauri build --debug --no-bundle",
    "build:release": "node scripts/sync-updater-pubkey.mjs && tauri build",
    "build:ui": "tsc -b && vite build",
    "import:obs-resources": "python3 scripts/import_obs_resources.py",
    "import:platform-catalog": "python3 scripts/import_platform_catalog.py",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync:version": "node scripts/sync-version.cjs",
    "sync:updater-key": "node scripts/sync-updater-pubkey.mjs",
    "version:patch": "npm version patch --no-git-tag-version && npm run sync:version",
    "version:minor": "npm version minor --no-git-tag-version && npm run sync:version",
    "version:major": "npm version major --no-git-tag-version && npm run sync:version",
    "release": "node scripts/release.mjs",
    "release:dry": "node scripts/release.mjs --dry-run",
    "release:patch": "npm run version:patch && node scripts/push-version-commit.cjs",
    "release:minor": "npm run version:minor && node scripts/push-version-commit.cjs",
    "release:major": "npm run version:major && node scripts/push-version-commit.cjs",
    "test": "node --test api/_lib/update-server.test.ts",
    "typecheck": "tsc -b",
    "tauri": "tauri"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@tauri-apps/api": "^2.10.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "posthog-js": "^1.360.2",
    "posthog-node": "^5.28.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "semver": "^7.7.4",
    "sonner": "^2.0.7",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@vercel/node": "^5.6.15",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
